rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function memberAccessPath(groupId, userId) {
      return /databases/$(database)/documents/groups/$(groupId)/memberAccess/$(userId);
    }

    function memberPath(groupId, memberId) {
      return /databases/$(database)/documents/groups/$(groupId)/members/$(memberId);
    }

    function isGroupMember(groupId) {
      return signedIn() && exists(memberAccessPath(groupId, request.auth.uid));
    }

    function memberRole(groupId) {
      return get(memberAccessPath(groupId, request.auth.uid)).data.role;
    }

    function canManageMembers(groupId) {
      return isGroupMember(groupId) && memberRole(groupId) in ['owner', 'admin'];
    }

    function canWriteExpenses(groupId) {
      return isGroupMember(groupId) && memberRole(groupId) in ['owner', 'admin', 'editor'];
    }

    function invitePath(inviteCode) {
      return /databases/$(database)/documents/invites/$(inviteCode);
    }

    function hasActiveInvite(groupId, inviteCode) {
      return inviteCode is string
        && exists(invitePath(inviteCode))
        && get(invitePath(inviteCode)).data.groupId == groupId
        && get(invitePath(inviteCode)).data.status == 'active';
    }

    function isSelfInviteJoin(groupId, userId) {
      return isSelf(userId)
        && request.resource.data.role == 'member'
        && request.resource.data.status == 'active'
        && hasActiveInvite(groupId, request.resource.data.inviteCode);
    }

    function isPaymentPayer(groupId) {
      return signedIn()
        && resource.data.fromMemberId is string
        && exists(memberPath(groupId, resource.data.fromMemberId))
        && get(memberPath(groupId, resource.data.fromMemberId)).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow create, read, update: if isSelf(userId);
      allow delete: if false;

      match /settings/{settingId} {
        allow read, write: if isSelf(userId);
      }
    }

    match /wallets/{walletId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (canManageMembers(request.resource.data.groupId) || request.resource.data.createdByUserId == request.auth.uid);
      allow update: if signedIn()
        && request.resource.data.groupId == resource.data.groupId
        && (canManageMembers(resource.data.groupId) || resource.data.status == 'active');
      allow delete: if false;
    }

    match /groups/{groupId} {
      allow create: if signedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isGroupMember(groupId) || (signedIn() && resource.data.ownerUserId == request.auth.uid);
      allow update: if canManageMembers(groupId);
      allow delete: if false;

      match /memberAccess/{userId} {
        allow read: if isSelf(userId) || canManageMembers(groupId);
        allow create: if canManageMembers(groupId)
          || (isSelf(userId) && request.resource.data.role == 'owner')
          || isSelfInviteJoin(groupId, userId);
        allow update: if canManageMembers(groupId);
        allow delete: if false;
      }

      match /members/{memberId} {
        allow read: if isGroupMember(groupId);
        allow create: if canManageMembers(groupId)
          || (signedIn()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.role == 'owner')
          || (signedIn()
            && request.resource.data.userId == request.auth.uid
            && isSelfInviteJoin(groupId, request.auth.uid));
        allow update: if canManageMembers(groupId);
        allow delete: if false;
      }

      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if canWriteExpenses(groupId);
        allow delete: if false;
      }

      match /payments/{paymentId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update: if canWriteExpenses(groupId) || isPaymentPayer(groupId);
        allow delete: if false;
      }

      match /activities/{activityId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) || (signedIn() && request.resource.data.actorUserId == request.auth.uid);
        allow update, delete: if false;
      }

      match /balanceSnapshots/{snapshotId} {
        allow read: if isGroupMember(groupId);
        allow write: if canWriteExpenses(groupId)
          || (signedIn() && !exists(/databases/$(database)/documents/groups/$(groupId)) && request.resource.data.groupId == groupId);
      }

      match /treasuryTransactions/{transactionId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if canManageMembers(groupId);
        allow delete: if false;
      }
    }
  }
}
