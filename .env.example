# Firebase is required for production persistence and realtime sync.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Arc payment settings.
# Leave RPC or USDC address blank to use Demo Mode with no onchain transaction.
VITE_ARC_RPC_URL=
VITE_ARC_CHAIN_ID=5042002
VITE_ARC_EXPLORER_URL=https://testnet.arcscan.app
VITE_ARC_USDC_ADDRESS=

# Optional. Enables WalletConnect in addition to injected browser wallets.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional. Enables Dynamic email/social auth and embedded wallets.
VITE_DYNAMIC_ENVIRONMENT_ID=
